# GZMO package: core — merged by scripts/lib/packages.sh

GZMO_EMBED_MODEL="nomic-embed-text"
GZMO_ENABLE_MODEL_ROUTING=off
GZMO_ENABLE_DROPZONE=on

GZMO_MULTIQUERY=on
GZMO_RERANK_LLM=on
